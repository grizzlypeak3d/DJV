{
  "shots": [
    {
      "id": "main-window",
      "window": { "w": 900, "h": 600 },
      "setup": [
        { "open": "etc/SampleData/BART_2021-02-07.#.jpg" },
        { "frame": 88 },
        { "tool": "Color Picker" },
        { "pick": [160, 90] }
      ],
      "annotate": [
        { "id": "MainWindow.MenuBar",       "caption": "Menu bar" },
        { "id": "MainWindow.ToolBar",       "caption": "Tool bars" },
        { "id": "MainWindow.TabBar",        "caption": "Tab bar" },
        { "id": "MainWindow.Viewport",      "caption": "Viewport" },
        { "id": "MainWindow.Timeline",      "caption": "Timeline" },
        { "id": "MainWindow.BottomToolBar", "caption": "Bottom tool bar" },
        { "id": "MainWindow.Tools",         "caption": "Tools" },
        { "id": "MainWindow.StatusBar",     "caption": "Status bar" }
      ]
    },
    {
      "id": "files-tool",
      "window": { "w": 900, "h": 600, "splitter2": 0.5 },
      "crop": "MainWindow.Tools",
      "setup": [
        { "open": "etc/SampleData/Cubes.0001.exr" },
        { "open": "etc/SampleData/Charlie.jpg" },
        { "open": "etc/SampleData/BART_2021-02-07.#.jpg" },
        { "tool": "Files", "expand": ["Compare"] },
        { "a": "BART" },
        { "b": "Charlie" },
        { "compare": "Wipe" }
      ],
      "annotate": [
        { "id": "Files.CurrentFile",    "caption": "Current file" },
        { "id": "Files.BFile",          "caption": "B file" },
        { "id": "Files.CurrentLayer",   "caption": "Current layer" },
        { "id": "Files.CompareMode",    "caption": "Compare mode" },
        { "id": "Files.CompareTime",    "caption": "Compare time" },
        { "id": "Files.CompareOptions", "caption": "Compare options" }
      ]
    },
    {
      "id": "ffmpeg-command",
      "window": { "w": 900, "h": 600, "splitter2": 0.6 },
      "crop": "MainWindow.Tools",
      "setup": [
        { "tool": "Settings", "expand": ["FFmpegCmd"] }
      ],
      "annotate": [
        { "id": "FFmpegCmd.FFmpegEdit", "caption": "ffmpeg" },
        { "id": "FFmpegCmd.FFprobeEdit", "caption": "ffprobe" }
      ]
    },
    {
      "id": "file-browser",
      "window": { "w": 900, "h": 600 },
      "setup": [
        { "nativeFileBrowser": true },
        { "fileBrowser": {
          "path": "etc/SampleData",
          "bellows": { "Drives": false }
        } }
      ],
      "annotate": []
    },
    {
      "id": "view-pixel-grid",
      "window": { "w": 900, "h": 600, "splitter2": 0.6 },
      "setup": [
        { "open": "etc/SampleData/BART_2021-02-07.#.jpg" },
        { "frame": 88 },
        { "tool": "View", "expand": ["Options"] },
        { "view": {
          "grid": { "enabled": true, "cellSize": 1, "labels": "Pixels" },
          "magnify": "nearest"
        } },
        { "zoom": 200 }
      ],
      "annotate": [
        { "id": "Viewport.Options.Magnify", "caption": "Magnify filter" }
      ]
    },
    {
      "id": "view-pixel-grid2",
      "window": { "w": 900, "h": 600, "splitter2": 0.6 },
      "setup": [
        { "open": "etc/SampleData/BART_2021-02-07.#.jpg" },
        { "frame": 88 },
        { "tool": "View", "expand": ["Grid"] },
        { "view": {
          "grid": { "enabled": true, "cellSize": 1, "labels": "Pixels" },
          "magnify": "nearest"
        } },
        { "zoom": 200 }
      ],
      "annotate": [
        { "id": "Viewport.Grid.Enabled", "caption": "Enable grid" },
        { "id": "Viewport.Grid.CellSize", "caption": "Grid cell size" },
        { "id": "Viewport.Grid.Labels", "caption": "Grid labels" }
      ]
    },
    {
      "id": "view-hud",
      "window": { "w": 900, "h": 600 },
      "layout": "horizontal",
      "crop": "MainWindow.Viewport",
      "setup": [
        { "open": "etc/SampleData/BART_2021-02-07.#.jpg" },
        { "frame": 88 },
        { "view": { "hud": true } },
        { "pick": [160, 90] }
      ],
      "annotate": [
        { "id": "Viewport.HUD.FileName", "caption": "File name" },
        { "id": "Viewport.HUD.Time", "caption": "Time" },
        { "id": "Viewport.HUD.ColorPicker", "caption": "Color picker" },
        { "id": "Viewport.HUD.Cache", "caption": "Cache" }
      ]
    },
    {
      "id": "playback-controls",
      "window": { "w": 900, "h": 600 },
      "layout": "horizontal",
      "setup": [
        { "open": "etc/SampleData/BART_2021-02-07.#.jpg" },
        { "frame": 88 }
      ],
      "annotate": [
        { "id": "Playback.Controls",    "caption": "Playback and frame controls" }
      ]
    },
    {
      "id": "playback-controls2",
      "window": { "w": 900, "h": 600 },
      "crop": "Playback.Controls",
      "setup": [
        { "open": "etc/SampleData/BART_2021-02-07.#.jpg" },
        { "frame": 88 }
      ],
      "annotate": [
        { "id": "Playback.PlaybackControls",    "caption": "Playback controls" },
        { "id": "Playback.Loop",                "caption": "Playback loop" },
        { "id": "Playback.PlaybackShuttle",     "caption": "Playback shuttle" },
        { "id": "Playback.FrameControls",       "caption": "Frame controls" },
        { "id": "Playback.FrameShuttle",        "caption": "Frame shuttle" },
        { "id": "Playback.CurrentFrame",        "caption": "Current frame" },
        { "id": "Playback.Duration",            "caption": "Duration" },
        { "id": "Playback.TimeUnits",           "caption": "Time units" },
        { "id": "Playback.Speed",               "caption": "Speed" }
      ]
    },
    {
      "id": "timeline",
      "settle": 3,
      "window": { "w": 900, "h": 600, "splitter": 0.4 },
      "crop": "MainWindow.Timeline",
      "cropFit": false,
      "setup": [
        { "open": "etc/SampleData/MultipleClips.otio" },
        { "frame": 30 },
        { "inOut": [10, 50] },
        { "timeline": { "minimize": false, "thumbnailSize": "Large" } }
      ],
      "annotate": [
        { "id": "Timeline.VideoTrack",  "caption": "Video track" },
        { "id": "Timeline.AudioTrack",  "caption": "Audio track" },
        { "id": "Timeline.VideoClip",  "caption": "Video clips" },
        { "id": "Timeline.AudioClip",  "caption": "Audio clips" },
        { "id": "Timeline.Gap",  "caption": "Gaps" }
      ]
    },
    {
      "id": "compare-tile",
      "window": { "w": 900, "h": 600, "splitter2": 0.5  },
      "setup": [
        { "open": "etc/SampleData/Cubes.0001.exr" },
        { "open": "etc/SampleData/Cubes.0001.exr" },
        { "open": "etc/SampleData/Cubes.0001.exr" },
        { "open": "etc/SampleData/Cubes.0001.exr" },
        { "layer": "Combined", "file": 0 },
        { "layer": "DiffCol",  "file": 1 },
        { "layer": "GlossDir", "file": 2 },
        { "layer": "Normal",   "file": 3 },
        { "tool": "Files", "expand": ["Compare"] },
        { "compare": "Tile" },
        { "a": 0 },
        { "b": 1 },
        { "b": 2 },
        { "b": 3 }
      ],
      "annotate": [
        { "id": "Files.CurrentLayer",   "caption": "Current layer" },
        { "id": "Files.CurrentFile",    "caption": "Current file" },
        { "id": "Files.BFile",          "caption": "B files" },
        { "id": "Files.CompareMode",    "caption": "Compare mode" }
      ]
    },
    {
      "id": "color-ocio",
      "window": { "w": 900, "h": 600, "splitter2": 0.5 },
      "crop": "MainWindow.Tools",
      "setup": [
        { "open": "etc/SampleData/BART_2021-02-07.#.jpg" },
        { "frame": 88 },
        { "ocio": "Built In" },
        { "tool": "Color", "expand": ["OCIO"] }
      ],
      "annotate": []
    },
    {
      "id": "tools",
      "window": { "w": 900, "h": 600, "splitter2": 0.6 },
      "setup": [
        { "open": "etc/SampleData/BART_2021-02-07.#.jpg" },
        { "frame": 88 },
        { "tool": "Information" }
      ],
      "annotate": [
        { "id": "MainWindow.ToolsToolBar",  "caption": "Tools tool bar" },
        { "id": "MainWindow.Tools",         "caption": "Information tool" }
      ]
    },
    {
      "id": "info-tool",
      "window": { "w": 900, "h": 600, "splitter2": 0.6 },
      "crop": "MainWindow.Tools",
      "setup": [
        { "open": "etc/SampleData/BART_2021-02-07.#.jpg" },
        { "frame": 88 },
        { "tool": "Information" }
      ],
      "annotate": [
        { "id": "Info.Copy",    "caption": "Copy" },
        { "id": "Info.Search",  "caption": "Search" }
      ]
    },
    {
      "id": "color-picker-tool",
      "window": { "w": 900, "h": 600, "splitter2": 0.6 },
      "crop": "MainWindow.Tools",
      "setup": [
        { "open": "etc/SampleData/BART_2021-02-07.#.jpg" },
        { "frame": 88 },
        { "tool": "Color Picker" },
        { "pick": [160, 90] }
      ],
      "annotate": []
    },
    {
      "id": "magnify-tool",
      "window": { "w": 900, "h": 600, "splitter2": 0.6 },
      "crop": "MainWindow.Tools",
      "setup": [
        { "open": "etc/SampleData/BART_2021-02-07.#.jpg" },
        { "frame": 88 },
        { "tool": "Magnify" },
        { "pick": [160, 90] }
      ],
      "annotate": []
    },
    {
      "id": "export-tool",
      "window": { "w": 900, "h": 600, "splitter2": 0.5 },
      "crop": "MainWindow.Tools",
      "setup": [
        { "open": "etc/SampleData/BART_2021-02-07.#.jpg" },
        { "frame": 88 },
        { "tool": "Export" }
      ],
      "annotate": []
    },
    {
      "id": "keyboard-shortcuts",
      "window": { "w": 900, "h": 600, "splitter2": 0.5 },
      "crop": "MainWindow.Tools",
      "setup": [
        { "open": "etc/SampleData/BART_2021-02-07.#.jpg" },
        { "frame": 88 },
        { "tool": "Settings", "expand": ["Shortcuts"] }
      ],
      "annotate": []
    },
    {
      "id": "custom-fonts",
      "window": { "w": 900, "h": 600, "splitter2": 0.5 },
      "setup": [
        { "open": "etc/SampleData/大平原.jpg" },
        { "frame": 88 },
        { "tool": "Settings", "expand": ["Style"] }
      ],
      "annotate": []
    }
  ]
}
