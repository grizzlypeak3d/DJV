# DJV documentation — local build / preview dependencies
# Lives at: docs/Gemfile
#   Setup:    bundle install
#   Preview:  bundle exec jekyll serve --livereload   ->  http://localhost:4000/DJV/

source "https://rubygems.org"

gem "jekyll", "~> 4.3"
gem "just-the-docs"   # version is pinned by Gemfile.lock; bump with `bundle update`

# Ruby 3.0+/3.4+ dropped these from the standard library; Jekyll's local
# server and a couple of dependencies still expect them.
gem "webrick", "~> 1.8"
gem "csv"
